# Backend (AI Core) — copy to .env at project root when running the API (e.g. uvicorn).
# Required for categorization: OpenAI. Required for override cache (Layer 1/2): Supabase.

OPENAI_API_KEY=your-openai-api-key

# Same Supabase project as the app. Without these, the backend cannot read manual_overrides,
# so user corrections will not be used on the next POST /categorize (in-memory store is empty).
PROJECT_URL=https://your-project.supabase.co
SERVICE_ROLE_KEY=your-service-role-key
