# Copy to .env and fill with your values. Used by the frontend and Claude Code agents.
# Do NOT add OPENAI_API_KEY, SERVICE_ROLE_KEY, or POSTGRES_* — those stay in the root .env (backend only).
# Expo requires EXPO_PUBLIC_ prefix for client-accessible env vars.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
